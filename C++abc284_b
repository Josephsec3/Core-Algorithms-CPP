#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t; cin >> t;
    while (t--){
      int n; cin >> n;
      int done=0, curr;
      while (n--){
        cin >> curr;
        done+=curr%2;
      }
      cout << done << "\n";
    }
}
